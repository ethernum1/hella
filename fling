-- ========== COMBINED ACTION LOGIC ==========
local function stopAction()
    if stickConnection then
        stickConnection:Disconnect()
        stickConnection = nil
        teleportToSafePlatform()
    end
    player:SetAttribute(ATTR_TARGET, "")
    player:SetAttribute(ATTR_FLING, false) 
    
    if actionButton and actionButton.Parent then
        actionButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        actionButton.Text = "Fling & Stick: " .. getSelectedCount() .. " Players"
    end
end

local function startAction()
    stopAction()

    local myChar = player.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local count = getSelectedCount()
    if count == 0 then return end

    player:SetAttribute(ATTR_FLING, true)
    player:SetAttribute(ATTR_TARGET, "MultiTarget")
    actionButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)

    local targetList = {}
    local currentIdx = 1
    local lastSwitchTime = os.clock() 
    local SWAP_DELAY = 12 
    
    local isWaitingOnPlatform = false 

    stickConnection = RunService.Stepped:Connect(function()
        targetList = {}
        for _, p in pairs(selectedPlayers) do
            if p and p.Parent and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local tHum = p.Character:FindFirstChildOfClass("Humanoid")
                if tHum and tHum.Health > 0 then
                    table.insert(targetList, p)
                end
            end
        end

        if #targetList == 0 then 
            if not isWaitingOnPlatform then
                isWaitingOnPlatform = true
                player:SetAttribute(ATTR_FLING, false) 
                teleportToSafePlatform()
                actionButton.Text = "Auto Wait: Waiting Respawn..."
            end
            return 
        end

        if isWaitingOnPlatform then
            isWaitingOnPlatform = false
            player:SetAttribute(ATTR_FLING, true) 
        end

        local currentTime = os.clock()
        if currentTime - lastSwitchTime >= SWAP_DELAY then
            lastSwitchTime = currentTime
            currentIdx = currentIdx + 1
        end

        if currentIdx > #targetList then
            currentIdx = 1
        end

        local targetPlayer = targetList[currentIdx]
        actionButton.Text = string.format("⚔️ Target [%d/%d]: %s", currentIdx, #targetList, targetPlayer.Name)

        local tChar = targetPlayer.Character
        local mChar = player.Character
        if not tChar or not mChar then return end

        local tRoot = tChar:FindFirstChild("HumanoidRootPart")
        local mRoot = mChar:FindFirstChild("HumanoidRootPart")
        
        if tRoot and mRoot then
            mRoot.CFrame = tRoot.CFrame
        end
    end)
end

actionButton.MouseButton1Click:Connect(function()
    if stickConnection then
        stopAction()
    else
        if getSelectedCount() > 0 then
            startAction()
        end
    end
end)

-- ========== PLAYER LIST ==========
local function togglePlayerSelection(p)
    if selectedPlayers[p.Name] then
        selectedPlayers[p.Name] = nil
        if playerButtons[p.Name] then
            playerButtons[p.Name].BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end
    else
        selectedPlayers[p.Name] = p
        if playerButtons[p.Name] then
            playerButtons[p.Name].BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        end
    end
    
    local count = getSelectedCount()
    if not stickConnection then
        actionButton.Text = "Fling & Stick: " .. count .. " Players"
    end
end

local function addPlayerButton(p)
    if p == player then return end

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -4, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 14
    btn.Text = p.Name
    btn.BorderSizePixel = 0
    btn.Parent = scrollFrame

    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 4)
    c.Parent = btn

    playerButtons[p.Name] = btn

    btn.MouseButton1Click:Connect(function()
        togglePlayerSelection(p)
    end)

    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 4)
end

local function removePlayerButton(p)
    if playerButtons[p.Name] then
        playerButtons[p.Name]:Destroy()
        playerButtons[p.Name] = nil
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 4)
    end
    if selectedPlayers[p.Name] then
        selectedPlayers[p.Name] = nil
        if stickConnection and getSelectedCount() == 0 then
            stopAction()
        elseif not stickConnection then
            actionButton.Text = "Fling & Stick: " .. getSelectedCount() .. " Players"
        end
    end
end

-- ========== INITIALIZATION & RESPAWN ==========
for _, p in ipairs(Players:GetPlayers()) do
    addPlayerButton(p)
end

playerAddedConn = Players.PlayerAdded:Connect(addPlayerButton)
playerRemovingConn = Players.PlayerRemoving:Connect(removePlayerButton)

