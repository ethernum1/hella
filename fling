local function getSelectedCount()
    local count = 0
    for _ in pairs(selectedPlayers) do count = count + 1 end
    return count
end

-- ========== SAFE SKY PLATFORM ==========
local skyPlatform = nil

local function createSafePlatform()
    if not skyPlatform or not skyPlatform.Parent then
        skyPlatform = Instance.new("Part")
        skyPlatform.Name = "SafeSkyPlatform"
        skyPlatform.Size = Vector3.new(50, 2, 50)
        skyPlatform.Position = Vector3.new(0, 10000, 0)
        skyPlatform.Anchored = true
        skyPlatform.CanCollide = true
        skyPlatform.Transparency = 0.5 
        skyPlatform.Material = Enum.Material.SmoothPlastic
        skyPlatform.Color = Color3.fromRGB(0, 200, 100)
        skyPlatform.Parent = workspace
    end
end

local function teleportToSafePlatform()
    createSafePlatform()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = skyPlatform.CFrame * CFrame.new(0, 4, 0)
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
        char.HumanoidRootPart.AssemblyAngularVelocity = Vector3.zero
    end
end

-- ====================================================
-- ========== ORIGINAL FLING LOGIC (100% SYNC) ========
-- ====================================================
local function startFlingLoop(humanoid)
    if humanoid == nil then return end
    local running = true

    local connAttr
    connAttr = player:GetAttributeChangedSignal(ATTR_FLING):Connect(function()
        if not player:GetAttribute(ATTR_FLING) then
            running = false
            if connAttr then connAttr:Disconnect() end
        end
    end)

    while running and humanoid.Parent do
        local moveVector = Vector3.one * 1e31
        pcall(function()
            humanoid:Move(moveVector)
        end)
        task.wait(0.1)
    end
end

local function onCharacterAdded(character)
    local humanoid = character:WaitForChild("Humanoid", 5)
    if not humanoid then return end

    if player:GetAttribute(ATTR_FLING) then
        task.spawn(function()
            startFlingLoop(humanoid)
        end)
    end
end

charAddedConn = player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then onCharacterAdded(player.Character) end

local flingAttrConn = player:GetAttributeChangedSignal(ATTR_FLING):Connect(function()
    if player:GetAttribute(ATTR_FLING) and player.Character then
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            task.spawn(function()
                startFlingLoop(humanoid)
            end)
        end
    end
end)
